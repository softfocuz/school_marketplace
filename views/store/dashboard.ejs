<%- include('../partials/header') %>

<section class="page-header">
  <h1>🏪 <%= store.name %> — Dashboard</h1>
</section>

<!-- STORE STATS -->
<div class="stats-grid">
  <div class="stat-card">
    <span class="stat-icon">📦</span>
    <div><h3><%= products.length %></h3><p>Products</p></div>
  </div>
  <div class="stat-card">
    <span class="stat-icon">🛒</span>
    <div><h3><%= orders.length %></h3><p>Orders</p></div>
  </div>
  <div class="stat-card">
    <span class="stat-icon">💰</span>
    <div><h3>₱<%= parseFloat(totalRevenue).toFixed(2) %></h3><p>Revenue</p></div>
  </div>
</div>

<!-- ADD PRODUCT FORM -->
<section>
  <h2 class="section-title">➕ Add New Product</h2>
  <form action="/store/my-store/product/add" method="POST" enctype="multipart/form-data" class="add-product-form">
    <div class="form-row">
      <div class="form-group">
        <label>Product Name</label>
        <input type="text" name="name" placeholder="Product name" required>
      </div>
      <div class="form-group">
        <label>Price (₱)</label>
        <input type="number" name="price" step="0.01" placeholder="0.00" required>
      </div>
      <div class="form-group">
        <label>Stock</label>
        <input type="number" name="stock" placeholder="0" value="0" min="0">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Description</label>
        <input type="text" name="description" placeholder="Short description...">
      </div>
      <div class="form-group">
        <label>Product Photo <span style="color:#888; font-size:0.82rem;">(optional)</span></label>
        <input type="file" name="product_image" accept="image/*">
        <small class="form-hint">📎 JPG, PNG, WEBP — Max 5MB</small>
      </div>
    </div>
    <button type="submit" class="btn btn-primary">Add Product</button>
  </form>
</section>

<!-- MY PRODUCTS -->
<section>
  <h2 class="section-title">📦 My Products</h2>
  <% if (products.length === 0) { %>
    <p class="empty-msg">No products yet. Add some above!</p>
  <% } else { %>
    <div class="products-grid">
      <% products.forEach(p => { %>
        <div class="product-card">

          <!-- Product image -->
          <% if (p.image) { %>
            <div class="product-img-real">
              <img src="/uploads/<%= p.image %>" alt="<%= p.name %>">
            </div>
          <% } else { %>
            <div class="product-img-placeholder">📦</div>
          <% } %>

          <div class="product-body">
            <h3><%= p.name %></h3>
            <p><%= p.description || '' %></p>

            <div class="product-footer">
              <span class="price">₱<%= parseFloat(p.price).toFixed(2) %></span>
              <!-- Stock badge — turns red when low -->
              <span class="stock-badge <%= p.stock === 0 ? 'out-of-stock' : p.stock <= 5 ? 'low-stock' : 'in-stock' %>">
                <%= p.stock === 0 ? '❌ Out of stock' : `📦 ${p.stock} left` %>
              </span>
            </div>

            <!-- Edit and Remove buttons -->
            <div style="display:flex; gap:8px; margin-top:10px;">
              <a href="/store/my-store/product/edit/<%= p.id %>" class="btn btn-sm btn-outline" style="flex:1; text-align:center;">
                ✏️ Edit
              </a>
              <form action="/store/my-store/product/delete/<%= p.id %>" method="POST"
                onsubmit="return confirm('Remove this product?')" style="flex:1;">
                <button type="submit" class="btn btn-sm btn-danger" style="width:100%;">🗑️ Remove</button>
              </form>
            </div>
          </div>

        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<!-- INCOMING ORDERS -->
<section>
  <h2 class="section-title">🛒 Incoming Orders</h2>
  <% if (orders.length === 0) { %>
    <p class="empty-msg">No orders yet.</p>
  <% } else { %>
    <% orders.forEach(order => { %>
      <div class="order-card order-<%= order.status %>">
        <div class="order-header">
          <div>
            <span class="order-id">Order #<%= order.id %></span>
            <span class="order-store">
              👤 <%= order.first_name ? order.first_name + ' ' + order.last_name : order.buyer_name %>
            </span>
          </div>
          <span class="order-status status-<%= order.status %>"><%= order.status.toUpperCase() %></span>
        </div>

        <div class="order-items">
          <% order.items.forEach(item => { %>
            <div class="order-item-line">
              <span><%= item.product_name %> x<%= item.quantity %></span>
              <span>₱<%= (item.price_at_order * item.quantity).toFixed(2) %></span>
            </div>
          <% }) %>
        </div>

        <div class="order-footer">
          <strong>Total: ₱<%= parseFloat(order.total_amount).toFixed(2) %></strong>
          <span class="order-date"><%= new Date(order.created_at).toLocaleDateString() %></span>

          <% if (order.status === 'pending') { %>
            <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap; margin-top:8px;">
              <form action="/store/my-store/order/confirm/<%= order.id %>" method="POST">
                <button type="submit" class="btn btn-sm btn-success">✅ Confirm</button>
              </form>
              <form action="/store/my-store/order/reject/<%= order.id %>" method="POST"
                onsubmit="return confirm('Reject this order?')"
                style="display:flex; gap:6px; align-items:center;">
                <input type="text" name="reject_reason" placeholder="Reason (optional)"
                  style="padding:5px 10px; border:2px solid #ddd; border-radius:6px; font-size:0.83rem; width:160px;">
                <button type="submit" class="btn btn-sm btn-danger">❌ Reject</button>
              </form>
            </div>
          <% } %>
        </div>
      </div>
    <% }) %>
  <% } %>
</section>

<%- include('../partials/footer') %>
