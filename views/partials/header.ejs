<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jikart</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar">
  <a href="/stores" class="nav-brand">
    <span><strong style="color:#FF7F50">Jikart</strong></span>
  </a>

  <div class="nav-links">
    <a href="/stores">Browse</a>

    <% if (currentUser) { %>
      <% if (currentUser.role === 'admin') { %>
        <a href="/admin/dashboard">Admin</a>
      <% } else if (currentUser.role === 'seller') { %>
        <a href="/store/my-store">My Store</a>
      <% } else { %>
        <a href="/orders/my-orders">My Orders</a>
      <% } %>

      <a href="/orders/cart" class="cart-btn">
        Cart <% if (cartCount > 0) { %><span class="cart-badge"><%= cartCount %></span><% } %>
      </a>

      <div class="nav-user">
        <span><%= currentUser.username %></span>
        <a href="/auth/logout" class="btn-logout">Logout</a>
      </div>
    <% } else { %>
      <a href="/auth/login" class="btn-login">Login</a>
      <a href="/auth/register" class="btn-register">Register</a>
    <% } %>
  </div>
</nav>

<div class="container">
  <% if (flashSuccess && flashSuccess.length > 0) { %>
    <div class="alert alert-success"><%= flashSuccess[0] %></div>
  <% } %>
  <% if (flashError && flashError.length > 0) { %>
    <div class="alert alert-error"><%= flashError[0] %></div>
  <% } %>
</div>

<main class="container">
