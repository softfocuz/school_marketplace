<%- include('../partials/header') %>

<section class="page-header">
  <h1>Admin Dashboard</h1>
</section>

<!-- STATS ROW -->
<div class="stats-grid">
  <div class="stat-card">
    <div>
      <h3><%= stats.totalUsers %></h3>
      <p>Buyers</p>
    </div>
  </div>
  <div class="stat-card">
    <div>
      <h3><%= stats.totalStores %></h3>
      <p>Stores</p>
    </div>
  </div>
  <div class="stat-card">
    <div>
      <h3><%= stats.totalOrders %></h3>
      <p>Total Orders</p>
    </div>
  </div>
  <div class="stat-card">
    <div>
      <h3>₱<%= parseFloat(stats.totalRevenue).toFixed(2) %></h3>
      <p>Revenue</p>
    </div>
  </div>
  <div class="stat-card stat-alert">
    <div>
      <h3><%= stats.pendingVerifications %></h3>
      <p>Pending Verifications</p>
    </div>
  </div>
</div>

<!-- ADMIN NAVIGATION -->
<div class="admin-nav">
  <a href="/admin/verifications" class="admin-nav-btn">🪪 Verifications</a>
  <a href="/admin/orders" class="admin-nav-btn">📦 All Orders</a>
  <a href="/admin/users" class="admin-nav-btn">👥 Users</a>
</div>

<!-- PENDING VERIFICATIONS -->
<section>
  <h2 class="section-title">Pending Verifications</h2>

  <% if (pendingVerifs.length === 0) { %>
    <p class="empty-msg">No pending verifications. All caught up!</p>
  <% } else { %>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>User</th>
            <th>Name</th>
            <th>Course</th>
            <th>Year</th>
            <th>Submitted</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% pendingVerifs.forEach(v => { %>
            <tr>
              <td><%= v.username %></td>
              <td><%= v.first_name %> <%= v.last_name %></td>
              <td><%= v.course %></td>
              <td><%= v.year_level %></td>
              <td><%= new Date(v.submitted_at).toLocaleDateString() %></td>
              <td>
                <a href="/admin/verifications/<%= v.id %>" class="btn btn-sm btn-outline">Review</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include('../partials/footer') %>
