<%- include('../partials/header') %>

<section class="page-header">
  <h1>All Orders</h1>
</section>

<div class="table-wrap">
  <table class="data-table">
    <thead>
      <tr>
        <th>#</th>
        <th>Buyer</th>
        <th>Store</th>
        <th>Items</th>
        <th>Total</th>
        <th>Status</th>
        <th>Date</th>
      </tr>
    </thead>
    <tbody>
      <% if (orders.length === 0) { %>
        <tr><td colspan="7" class="empty-cell">No orders yet.</td></tr>
      <% } %>
      <% orders.forEach(order => { %>
        <tr>
          <td>#<%= order.id %></td>
          <td>
            <%= order.buyer_name %>
            <% if (order.first_name) { %>
              <br><small><%= order.first_name %> <%= order.last_name %></small>
            <% } %>
          </td>
          <td><%= order.store_name %></td>
          <td>
            <% order.items.forEach(item => { %>
              <div><%= item.product_name %> x<%= item.quantity %></div>
            <% }) %>
          </td>
          <td>₱<%= parseFloat(order.total_amount).toFixed(2) %></td>
          <td><span class="badge-status status-<%= order.status %>"><%= order.status %></span></td>
          <td><%= new Date(order.created_at).toLocaleDateString() %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<a href="/admin/dashboard" class="btn btn-outline" style="margin-top:20px">← Dashboard</a>
<%- include('../partials/footer') %>
