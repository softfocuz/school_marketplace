<%- include('../partials/header') %>

<section class="page-header">
  <h1>Identity Verification</h1>
  <p>Verify your identity to start placing orders in the marketplace.</p>
</section>

<div class="verif-form-wrap">
  <div class="info-box">
    <strong>Why do we verify?</strong>
    Verification protects sellers from fraudulent buyers and keeps our marketplace safe and trusted for everyone in the campus community.
  </div>

  <form action="/verification/submit" method="POST" enctype="multipart/form-data" class="verif-form" id="verifForm">

    <!-- BUYER TYPE -->
    <p class="section-label">Who are you?</p>
    <div class="type-toggle">
      <label class="type-option" id="opt-student">
        <input type="radio" name="buyer_type" value="student"
          <%= (!verification || verification.buyer_type !== 'nonstudent') ? 'checked' : '' %>
          onchange="toggleType('student')">
        <div class="type-label-inner">
          <span class="type-icon">🎓</span>
          <span class="type-text">Student</span>
          <small>Enrolled in a school or university</small>
        </div>
      </label>
      <label class="type-option" id="opt-nonstudent">
        <input type="radio" name="buyer_type" value="nonstudent"
          <%= (verification && verification.buyer_type === 'nonstudent') ? 'checked' : '' %>
          onchange="toggleType('nonstudent')">
        <div class="type-label-inner">
          <span class="type-icon">👔</span>
          <span class="type-text">Non-Student</span>
          <small>Teacher, parent, staff, or community member</small>
        </div>
      </label>
    </div>

    <hr class="divider">

    <!-- PERSONAL INFO -->
    <p class="section-label">Personal Information</p>
    <div class="form-row">
      <div class="form-group">
        <label>First Name *</label>
        <input type="text" name="first_name" placeholder="Your first name" required
          value="<%= verification ? verification.first_name : '' %>">
      </div>
      <div class="form-group">
        <label>Last Name *</label>
        <input type="text" name="last_name" placeholder="Your last name" required
          value="<%= verification ? verification.last_name : '' %>">
      </div>
    </div>

    <div class="form-group">
      <label>Contact Number *</label>
      <input type="text" name="contact_number" placeholder="09XXXXXXXXX or +639XXXXXXXXX" required
        value="<%= verification ? verification.contact_number : '' %>">
      <small class="form-hint">Must be your own active Philippine mobile number.</small>
    </div>

    <!-- STUDENT FIELDS -->
    <div id="student-fields">
      <hr class="divider">
      <p class="section-label">Student Details</p>
      <div class="form-group">
        <label>School / University *</label>
        <input type="text" name="school" placeholder="e.g. University of the Philippines Visayas"
          value="<%= verification ? (verification.school || '') : '' %>">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Year Level *</label>
          <select name="year_level">
            <option value="">-- Select Year --</option>
            <% ['1st Year', '2nd Year', '3rd Year', '4th Year', '5th Year', 'Graduate'].forEach(y => { %>
              <option value="<%= y %>" <%= verification && verification.year_level === y ? 'selected' : '' %>><%= y %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Level</label>
          <select name="student_level" id="studentLevelSelect" onchange="toggleProgram(this)">
            <option value="college" <%= !verification || !verification.student_level || verification.student_level === 'college' ? 'selected' : '' %>>College</option>
            <option value="senior_high" <%= verification && verification.student_level === 'senior_high' ? 'selected' : '' %>>Senior High School</option>
            <option value="junior_high" <%= verification && verification.student_level === 'junior_high' ? 'selected' : '' %>>Junior High School</option>
            <option value="elementary" <%= verification && verification.student_level === 'elementary' ? 'selected' : '' %>>Elementary</option>
          </select>
        </div>
      </div>
      <div class="form-group" id="program-field">
        <label>Course / Program *</label>
        <input type="text" name="course" placeholder="e.g. BSIT, BSCS, BSBA, BS Nursing"
          value="<%= verification ? (verification.course || '') : '' %>">
        <small class="form-hint">Required for college students.</small>
      </div>
      <div class="form-group">
        <label>Class Schedule</label>
        <input type="text" name="schedule" placeholder="e.g. MWF 8AM-12PM / TTH 1PM-5PM"
          value="<%= verification ? (verification.schedule || '') : '' %>">
      </div>
      <div class="form-group">
        <label>Upload Student ID Photo *</label>
        <input type="file" name="student_id_photo" accept="image/*" id="id-photo-input">
        <% if (verification && verification.student_id_photo) { %>
          <small class="form-hint">Previous photo on file. Upload a new one to replace it.</small>
        <% } else { %>
          <small class="form-hint">JPG or PNG only. Max 5MB. Must show your name and school clearly.</small>
        <% } %>
      </div>
    </div>

    <!-- NON-STUDENT FIELDS -->
    <div id="nonstudent-fields" style="display:none;">
      <hr class="divider">
      <p class="section-label">Occupation Details</p>
      <div class="form-row">
        <div class="form-group">
          <label>Occupation *</label>
          <input type="text" name="occupation" placeholder="e.g. Teacher, Staff, Parent, Employee"
            value="<%= verification ? (verification.occupation || '') : '' %>">
        </div>
        <div class="form-group">
          <label>Workplace / Affiliation *</label>
          <input type="text" name="workplace" placeholder="e.g. School Name, Company, N/A"
            value="<%= verification ? (verification.workplace || '') : '' %>">
        </div>
      </div>
      <div class="form-group">
        <label>Home / Office Address *</label>
        <input type="text" name="home_address" placeholder="Your complete address"
          value="<%= verification ? (verification.home_address || '') : '' %>">
        <small class="form-hint">This helps us verify you are within the delivery area.</small>
      </div>
    </div>

    <!-- DELIVERY PREFERENCES -->
    <hr class="divider">
    <p class="section-label">Delivery Preferences</p>
    <div class="info-box info-note" style="margin-bottom:16px;">
      <strong>Note:</strong> These are your usual preferences. You can still enter a specific address each time you order.
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Preferred Delivery Time</label>
        <input type="text" name="delivery_time" placeholder="e.g. 10AM-12PM, After 2PM"
          value="<%= verification ? (verification.delivery_time || '') : '' %>">
      </div>
      <div class="form-group">
        <label>Preferred Delivery Day</label>
        <input type="text" name="preferred_date" placeholder="e.g. Weekdays, Mondays only, Any day"
          value="<%= verification ? (verification.preferred_date || '') : '' %>">
      </div>
    </div>
    <div class="form-group">
      <label>Default Delivery Address</label>
      <input type="text" name="default_address" placeholder="e.g. Room 203, Building A, near the canteen"
        value="<%= verification ? (verification.default_address || '') : '' %>">
    </div>

    <!-- FACEBOOK INFO -->
    <hr class="divider">
    <p class="section-label">Facebook Account Info</p>
    <div class="info-box info-note">
      <strong>Note:</strong> Your Facebook info is kept private and only accessible by admins and sellers for verification and dispute resolution. It will never be shared publicly.
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Facebook Profile Link or Full Name *</label>
        <input type="text" name="facebook_link" placeholder="https://facebook.com/yourname or Your FB Name" required
          value="<%= verification ? verification.facebook_link : '' %>">
      </div>
      <div class="form-group">
        <label>Describe Your Profile Photo *</label>
        <input type="text" name="facebook_describe" placeholder="e.g. Selfie with blue shirt, beach cover photo" required
          value="<%= verification ? verification.facebook_describe : '' %>">
        <small class="form-hint">Helps admins identify your account if needed.</small>
      </div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">
        <%= verification && verification.status === 'rejected' ? 'Resubmit Verification' : 'Submit Verification' %>
      </button>
      <a href="/stores" class="btn btn-outline">Back to Stores</a>
    </div>
  </form>
</div>

<style>
.type-toggle { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 8px; }
.type-option {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border: 2px solid var(--border);
  border-radius: 12px;
  padding: 16px 20px;
  cursor: pointer;
  transition: all 0.2s;
  flex: 1;
  min-width: 200px;
}
.type-option:has(input:checked) { border-color: var(--primary); background: #eef2ff; }
.type-option input { display: none; }
.type-label-inner { display: flex; flex-direction: column; gap: 2px; }
.type-icon { font-size: 1.6rem; margin-bottom: 4px; }
.type-text { font-weight: 700; font-size: 1rem; color: var(--secondary); }
.type-option small { font-size: 0.78rem; color: var(--text-muted); }
</style>

<script>
function toggleType(type) {
  const isStudent = type === 'student';
  document.getElementById('student-fields').style.display = isStudent ? 'block' : 'none';
  document.getElementById('nonstudent-fields').style.display = isStudent ? 'none' : 'block';
}
function toggleProgram(sel) {
  const isCollege = sel.value === 'college';
  document.getElementById('program-field').style.display = isCollege ? 'block' : 'none';
}
const currentType = document.querySelector('input[name="buyer_type"]:checked')?.value || 'student';
toggleType(currentType);
const levelSel = document.getElementById('studentLevelSelect');
if (levelSel) toggleProgram(levelSel);
</script>

<%- include('../partials/footer') %>
