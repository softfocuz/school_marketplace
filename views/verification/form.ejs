<%- include('../partials/header') %>

<section class="page-header">
  <h1>Student Verification</h1>
  <p>Please verify your identity to place orders in the marketplace.</p>
</section>

<div class="verif-form-wrap">
  <div class="info-box">
    <strong>Why do we verify?</strong>
    <p>Verification helps protect sellers from scam buyers and ensures a safe, trusted community marketplace.</p>
  </div>

  <form action="/verification/submit" method="POST" enctype="multipart/form-data" class="verif-form">

    <div class="form-row">
      <div class="form-group">
        <label>First Name *</label>
        <input type="text" name="first_name" placeholder="First Name" required
          value="<%= verification ? verification.first_name : '' %>">
      </div>
      <div class="form-group">
        <label>Last Name *</label>
        <input type="text" name="last_name" placeholder="Last Name" required
          value="<%= verification ? verification.last_name : '' %>">
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Course *</label>
        <input type="text" name="course" placeholder="e.g. BSCS" required
          value="<%= verification ? verification.course : '' %>">
      </div>
      <div class="form-group">
        <label>Year Level *</label>
        <select name="year_level" required>
          <option value="">-- Select Year --</option>
          <% ['1st Year', '2nd Year', '3rd Year', '4th Year'].forEach(y => { %>
            <option value="<%= y %>" <%= verification && verification.year_level === y ? 'selected' : '' %>>
              <%= y %>
            </option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="form-group">
      <label>Delivery Address *</label>
      <input type="text" name="schedule" placeholder=" GCT Canteen" required
        value="<%= verification ? verification.schedule : '' %>">
    </div>


    <div class="form-group">
      <label>Contact Number *</label>
      <input type="text" name="contact_number" placeholder="09XXXXXXXXX or +639XXXXXXXXX" required
        value="<%= verification ? verification.contact_number : '' %>">
      <small class="form-hint">Must be your own Philippine mobile number to prevent scam buyers.</small>
    </div>

    <hr class="divider">
    <p class="section-label">Facebook Account Info</p>

    <div class="info-box info-note">
      <strong>Note:</strong> We ask for your Facebook account information only to be aware of buy tripping incidents and to help resolve disputes. Your information is kept private and only accessible by admins.
    </div>

    <div class="form-group">
      <label>Facebook Profile Link or Name *</label>
      <input type="text" name="facebook_link" placeholder="https://facebook.com/yourname or Your Full Name on FB" required
        value="<%= verification ? verification.facebook_link : '' %>">
    </div>

    <div class="form-group">
      <label>Describe your Facebook Profile *</label>
      <textarea name="facebook_describe" rows="3"
        placeholder="e.g. Profile picture is a selfie with a blue shirt, cover photo is beach scenery..."
        required><%= verification ? verification.facebook_describe : '' %></textarea>
      <small class="form-hint">This helps us identify your account if needed.</small>
    </div>

    <hr class="divider">

    <div class="form-group">
      <label>Upload Student ID Photo *</label>
      <input type="file" name="student_id_photo" accept="image/*"
        <%= verification && verification.status !== 'rejected' ? '' : 'required' %>>
      <% if (verification && verification.student_id_photo) { %>
        <small class="form-hint">Previous photo on file. Upload a new one to replace it.</small>
      <% } else { %>
        <small class="form-hint">Accepted: JPG, PNG. Max size: 5MB</small>
      <% } %>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">
        <%= verification && verification.status === 'rejected' ? 'Resubmit Verification' : 'Submit Verification' %>
      </button>
      <a href="/stores" class="btn btn-outline">← Back to Stores</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
